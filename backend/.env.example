# --- Required ---
DATABASE_URL="mysql://user:password@localhost:3306/pabw"
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- Optional ---
NODE_ENV=development
PORT=3000

# Comma-separated list of allowed origins. Use "*" only in dev.
CORS_ORIGIN=http://localhost:3001

# JWT
JWT_EXPIRES_IN=1d

# Password hashing
BCRYPT_SALT_ROUNDS=12

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10

# --- LLM Provider ---
# Set LLM_PROVIDER to "gemini" (cloud, default) or "ollama" (local).
# To use local LLM: change to ollama and uncomment OLLAMA_* below.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Local LLM (Ollama) — uncomment and set LLM_PROVIDER=ollama to use ---
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=qwen2.5:7b
