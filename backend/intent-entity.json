{
  "intents": [
    {
      "intent": "search_product",
      "description": "User wants to search or browse everyday products",
      "examples": [
        "Cari baju putih",
        "Ada sepatu murah?",
        "Tampilkan produk sabun mandi"
      ],
      "entities": [
        {
          "name": "product",
          "type": "string",
          "description": "Name or category of the everyday item being searched",
          "example": "baju, sepatu, sabun, tas"
        },
        {
          "name": "color",
          "type": "string",
          "description": "Color filter for the product",
          "example": "putih, hitam, biru"
        },
        {
          "name": "price",
          "type": "number",
          "description": "Price filter or range in IDR",
          "example": "50000, 100 ribu"
        },
        {
          "name": "action",
          "type": "string",
          "enum": ["search", "filter", "sort"],
          "description": "Action to perform on product list"
        }
      ]
    },
    {
      "intent": "add_to_cart",
      "description": "User wants to add an item to their cart",
      "examples": [
        "Tambahkan sabun ini ke keranjang",
        "Masukkan 2 baju ke cart"
      ],
      "entities": [
        {
          "name": "product",
          "type": "string",
          "description": "Name of the item to add",
          "example": "sabun mandi, kaos polos"
        },
        {
          "name": "action",
          "type": "string",
          "enum": ["add", "remove", "update_quantity"],
          "description": "Cart action to perform"
        }
      ]
    },
    {
      "intent": "checkout",
      "description": "User wants to proceed to checkout from their cart",
      "examples": [
        "Checkout sekarang",
        "Lanjut ke pembayaran",
        "Beli semua item di keranjang"
      ],
      "entities": [
        {
          "name": "action",
          "type": "string",
          "enum": ["checkout"],
          "description": "Trigger checkout flow"
        },
        {
          "name": "address",
          "type": "string",
          "description": "Delivery address selected by user",
          "example": "Jl. Merdeka No.1, Balikpapan"
        }
      ]
    },
    {
      "intent": "payment",
      "description": "User wants to complete or inquire about payment",
      "examples": [
        "Bayar pakai ewallet",
        "Konfirmasi pembayaran order saya",
        "Status pembayaran order #12"
      ],
      "entities": [
        {
          "name": "action",
          "type": "string",
          "enum": ["pay", "check_status", "cancel"],
          "description": "Payment action to perform"
        },
        {
          "name": "payment_method",
          "type": "string",
          "enum": ["ewallet"],
          "description": "Payment method chosen by user"
        },
        {
          "name": "order_id",
          "type": "number",
          "description": "Order ID related to the payment",
          "example": 12
        },
        {
          "name": "price",
          "type": "number",
          "description": "Amount to be paid in IDR",
          "example": 75000
        }
      ]
    },
    {
      "intent": "track_order",
      "description": "User wants to track the delivery status of their order",
      "examples": [
        "Dimana pesanan saya?",
        "Status pengiriman order #7",
        "Sudah sampai mana kurirnya?"
      ],
      "entities": [
        {
          "name": "order_id",
          "type": "number",
          "description": "Order or order item ID to track",
          "example": 7
        },
        {
          "name": "action",
          "type": "string",
          "enum": ["track", "check_status"],
          "description": "Tracking action"
        },
        {
          "name": "product",
          "type": "string",
          "description": "Product name to identify the order item",
          "example": "kaos polos, sepatu kets"
        }
      ]
    }
  ]
}
