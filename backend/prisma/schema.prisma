generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  1. USER & ACCESS SYSTEM
// ============================================================

model User {
  id           Int      @id @default(autoincrement())
  fullName     String   @map("full_name")
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  roles              UserRole[]
  addresses          Address[]
  wallet             Wallet?
  sellerApplications SellerApplication[]
  stores             Store[]
  carts              Cart[]
  buyerOrders        Order[]              @relation("BuyerOrders")
  sellerOrderItems   OrderItem[]          @relation("SellerOrderItems")
  orderHistories     OrderStatusHistory[] @relation("OrderStatusUpdatedBy")
  kurirAssignments   KurirAssignment[]
  chatSessions       ChatSession[]
  reviews            Review[]

  @@map("users")
}

model Role {
  id       Int        @id @default(autoincrement())
  nameRole String     @map("name_role")
  users    UserRole[]

  @@map("role")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Address {
  id         Int    @id @default(autoincrement())
  userId     Int    @map("user_id")
  address    String @db.Text
  city       String
  postalCode String @map("postal_code")

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ============================================================
//  2. EWALLET SYSTEM
// ============================================================

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int?     @unique @map("user_id")
  balance   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user         User?               @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@index([userId])
  @@map("ewallet")
}

model WalletTransaction {
  id            Int      @id @default(autoincrement())
  eWalletId     Int?     @map("e_wallet_id")
  orderId       Int?     @map("order_id")
  type          String // enum: topup, payment, withdrawal
  amount        Int
  balanceBefore Int      @map("balance_before")
  balanceAfter  Int      @map("balance_after")
  createdAt     DateTime @default(now()) @map("created_at")

  wallet Wallet? @relation(fields: [eWalletId], references: [id])
  order  Order?  @relation(fields: [orderId], references: [id])

  @@index([eWalletId])
  @@index([orderId])
  @@map("ewallet_transaction")
}

// ============================================================
//  3. SELLER & STORE SYSTEM
// ============================================================

model SellerApplication {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  storeName String   @map("store_name")
  phone     String
  status    String   @default("pending") // pending, approved, rejected
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("seller_applications")
}

model Store {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  storeName String   @map("store_name")
  phone     String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id])
  products Product[]

  @@index([userId])
  @@map("stores")
}

// ============================================================
//  4. PRODUCT SYSTEM
// ============================================================

model Category {
  id           Int       @id @default(autoincrement())
  categoryName String    @map("category_name")
  products     Product[]

  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  categoryId  Int?     @map("category_id")
  storeId     Int?     @map("store_id")
  name        String
  desc        String   @db.Text
  price       Int
  stock       Int
  stockStatus String   @map("stock_status") // tersedia, kosong
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  category   Category?   @relation(fields: [categoryId], references: [id])
  store      Store?      @relation(fields: [storeId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([categoryId])
  @@index([storeId])
  @@map("product_list")
}

// ============================================================
//  5. CART & ORDERS SYSTEM
// ============================================================

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  status    String   @default("active") // active, checked_out
  createdAt DateTime @default(now()) @map("created_at")

  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]
  orders Order[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id            Int      @id @default(autoincrement())
  cartId        Int      @map("cart_id")
  productListId Int      @map("product_list_id")
  qty           Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productListId], references: [id])

  @@unique([cartId, productListId])
  @@index([cartId])
  @@index([productListId])
  @@map("carts_items")
}

model Order {
  id            Int       @id @default(autoincrement()) @map("order_id")
  buyerId       Int       @map("buyer_id")
  cartId        Int       @map("cart_id")
  addressId     Int       @map("address_id")
  totalAmount   Int       @map("total_amount")
  paymentStatus String    @default("pending") @map("payment_status")
  createdAt     DateTime  @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")

  buyer            User                 @relation("BuyerOrders", fields: [buyerId], references: [id])
  cart             Cart                 @relation(fields: [cartId], references: [id])
  address          Address              @relation(fields: [addressId], references: [id])
  items            OrderItem[]
  histories        OrderStatusHistory[]
  payment          Payment?
  reviews          Review[]
  walletTxns       WalletTransaction[]
  kurirAssignments KurirAssignment[]

  @@index([buyerId])
  @@map("orders")
}

model OrderItem {
  id              Int      @id @default(autoincrement()) @map("order_item_id")
  orderId         Int      @map("order_id")
  productListId   Int      @map("product_list_id")
  sellerId        Int      @map("seller_id")
  productNameSnap String   @map("product_name_snap")
  priceSnap       Int      @map("price_snap")
  qty             Int      @default(1)
  status          String   @default("menunggu_penjual")
  createdAt       DateTime @default(now()) @map("created_at")

  order             Order            @relation(fields: [orderId], references: [id])
  product           Product          @relation(fields: [productListId], references: [id])
  seller            User             @relation("SellerOrderItems", fields: [sellerId], references: [id])
  kurirAssignment   KurirAssignment? @relation(fields: [kurirAssignmentId], references: [id])
  kurirAssignmentId Int?

  @@index([orderId])
  @@index([productListId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  updatedBy Int      @map("updated_by")
  status    String
  createdAt DateTime @default(now()) @map("created_at")

  order   Order @relation(fields: [orderId], references: [id])
  updater User  @relation("OrderStatusUpdatedBy", fields: [updatedBy], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

model Payment {
  id      Int       @id @default(autoincrement()) @map("payment_id")
  orderId Int       @unique @map("order_id")
  amount  Int
  method  String // enum: ewallet, dll
  status  String    @default("pending")
  paidAt  DateTime? @map("paid_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ============================================================
//  6. KURIR SYSTEM
// ============================================================

model KurirAssignment {
  id          Int       @id @default(autoincrement()) @map("kurir_assignment_id")
  orderId     Int       @map("order_id")
  kurirId     Int       @map("kurir_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  pickupAt    DateTime? @map("pickup_at")
  deliveredAt DateTime? @map("delivered_at")

  order      Order       @relation(fields: [orderId], references: [id])
  kurir      User        @relation(fields: [kurirId], references: [id])
  orderItems OrderItem[]

  @@index([orderId])
  @@index([kurirId])
  @@map("kurir_assignments")
}

// ============================================================
//  7. AI CHATBOT & REVIEW
// ============================================================

model ChatSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id])
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id                  Int      @id @default(autoincrement())
  sessionId           Int      @map("session_id")
  role                String   @map("sender") // user, assistant
  content             String   @map("message") @db.Text
  intent              String?
  suggestedProductIds Json?    @map("suggested_product_ids")
  entities            Json?
  createdAt           DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("chat_messages")
}

model Review {
  id            Int      @id @default(autoincrement())
  productListId Int?     @map("product_list_id")
  orderItemsId  Int?     @map("order_items_id")
  reviewerId    Int?     @map("reviewer_id")
  rating        Int      @db.TinyInt
  comment       String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  product  Product? @relation(fields: [productListId], references: [id])
  order    Order?   @relation(fields: [orderItemsId], references: [id])
  reviewer User?    @relation(fields: [reviewerId], references: [id])

  @@map("review")
}
