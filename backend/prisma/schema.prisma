generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  seller
}

model User {
  id                   Int                  @id @default(autoincrement())
  full_name            String
  email                String               @unique
  password             String
  role                 UserRole
  products             Product[]
  addresses            Address[]
  carts                Cart[]
  buyerOrders          Order[]              @relation("BuyerOrders")
  sellerOrderItems     OrderItem[]          @relation("SellerOrderItems")
  orderStatusHistories OrderStatusHistory[] @relation("OrderStatusUpdatedBy")

  @@map("users")
}

enum StockStatus {
  tersedia
  habis
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String
  price       Int
  stock       Int
  stockStatus StockStatus @map("stock_status")
  imageUrl    String      @map("image_url")
  sellerId    Int         @map("seller_id")
  createdAt   DateTime    @default(now()) @map("created_at")

  seller     User        @relation(fields: [sellerId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("products")
}

model Address {
  id         Int     @id @default(autoincrement()) @map("address_id")
  userId     Int     @map("user_id")
  address    String
  city       String
  postalCode String  @map("postal_code")

  user       User    @relation(fields: [userId], references: [id])
  orders     Order[]

  @@map("addresses")
}

enum PaymentMethod {
  ewallet
}

enum PaymentStatus {
  pending
  paid
  failed
}

model Payment {
  id        Int           @id @default(autoincrement()) @map("payment_id")
  orderId   Int           @unique @map("order_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(15, 2)
  status    PaymentStatus @default(pending)
  paidAt    DateTime?     @map("paid_at")
  createdAt DateTime      @default(now()) @map("created_at")

  order      Order        @relation(fields: [orderId], references: [id])

  @@map("payments")
}

enum CartStatus {
  active
  checked_out
  abandoned
}

model Cart {
  id           Int         @id @default(autoincrement()) @map("cart_id")
  userId       Int         @map("user_id")
  status       CartStatus  @default(active)
  checkedOutAt DateTime?   @map("checked_out_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  user         User        @relation(fields: [userId], references: [id])
  items        CartItem[]
  orders       Order[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement()) @map("cart_item_id")
  cartId    Int      @map("cart_id")
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  cart      Cart     @relation(fields: [cartId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id            Int                @id @default(autoincrement()) @map("order_id")
  buyerId       Int                @map("buyer_id")
  cartId        Int                @map("cart_id")
  addressId     Int                @map("address_id")
  totalAmount   Decimal            @db.Decimal(15, 2) @map("total_amount")
  paymentStatus PaymentStatus      @default(pending) @map("payment_status")
  createdAt     DateTime           @default(now()) @map("created_at")
  paidAt        DateTime?          @map("paid_at")

  buyer         User               @relation("BuyerOrders", fields: [buyerId], references: [id])
  cart          Cart               @relation(fields: [cartId], references: [id])
  address       Address            @relation(fields: [addressId], references: [id])
  items         OrderItem[]
  histories     OrderStatusHistory[]
  payment       Payment?

  @@map("orders")
}

enum OrderItemStatus {
  menunggu_penjual
  diproses_penjual
  menunggu_kurir
  sedang_dikirim
  sampai_di_tujuan
  diterima_pembeli
  transaksi_gagal
}

model OrderItem {
  id              Int             @id @default(autoincrement()) @map("order_item_id")
  orderId         Int             @map("order_id")
  productId       Int             @map("product_id")
  sellerId        Int             @map("seller_id")
  productNameSnap String          @map("product_name_snap")
  priceSnap       Decimal         @db.Decimal(15, 2) @map("price_snap")
  qty             Int
  subtotal        Decimal         @db.Decimal(15, 2)
  status          OrderItemStatus @default(menunggu_penjual)
  createdAt       DateTime        @default(now()) @map("created_at")

  order           Order           @relation(fields: [orderId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  seller          User            @relation("SellerOrderItems", fields: [sellerId], references: [id])

  @@map("order_items")
}

enum OrderHistoryStatus {
  menunggu_penjual
  diproses_penjual
  menunggu_kurir
  sedang_dikirim
  sampai_di_tujuan
  diterima_pembeli
  transaksi_gagal
}

model OrderStatusHistory {
  id         Int                @id @default(autoincrement())
  orderId    Int                @map("order_id")
  status     OrderHistoryStatus
  updatedBy  Int                @map("updated_by")
  createdAt  DateTime           @default(now()) @map("created_at")

  order      Order              @relation(fields: [orderId], references: [id])
  updater    User               @relation("OrderStatusUpdatedBy", fields: [updatedBy], references: [id])

  @@map("order_status_history")
}
